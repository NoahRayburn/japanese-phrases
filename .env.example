# Copy to `.env.local` for local development.
# In production, set these as repo Secrets in GitHub:
#   Settings → Secrets and variables → Actions → New repository secret
# Then the deploy workflow will inject them at build time.
#
# Get these from the Firebase Console:
#   1. https://console.firebase.google.com → Add project (free tier)
#   2. In the project, click </> "Add app" → Web → register
#   3. Copy the values from the firebaseConfig object
#   4. In Build → Firestore Database → Create database (start in TEST mode)
#   5. Set the security rules below in Firestore → Rules:
#
#      rules_version = '2';
#      service cloud.firestore {
#        match /databases/{database}/documents {
#          match /jp-learner/{doc} {
#            allow read, write: if true;
#          }
#        }
#      }
#
# These rules make the single `jp-learner` collection publicly read/write,
# which is fine for a personal app on an obscure URL with non-sensitive data.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
