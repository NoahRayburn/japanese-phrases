[
  { "id": "g01", "english": "Excuse me / Sorry", "japanese": "すみません", "romaji": "sumimasen", "category": "greetings", "modes": ["say", "hear"], "notes": "The most versatile polite phrase. Use to get attention, apologize, or thank someone for help." },
  { "id": "g02", "english": "Thank you (polite)", "japanese": "ありがとうございます", "romaji": "arigatou gozaimasu", "category": "greetings", "modes": ["say", "hear"] },
  { "id": "g03", "english": "Hello / Good afternoon", "japanese": "こんにちは", "romaji": "konnichiwa", "category": "greetings", "modes": ["say", "hear"] },
  { "id": "g04", "english": "Good morning (polite)", "japanese": "おはようございます", "romaji": "ohayou gozaimasu", "category": "greetings", "modes": ["say", "hear"] },
  { "id": "g05", "english": "Good evening", "japanese": "こんばんは", "romaji": "konbanwa", "category": "greetings", "modes": ["say", "hear"] },
  { "id": "g06", "english": "Goodbye", "japanese": "さようなら", "romaji": "sayounara", "category": "greetings", "modes": ["say", "hear"], "notes": "Fairly formal — じゃあね (jaa ne) is more casual." },
  { "id": "g07", "english": "Yes", "japanese": "はい", "romaji": "hai", "category": "greetings", "modes": ["say", "hear"] },
  { "id": "g08", "english": "No", "japanese": "いいえ", "romaji": "iie", "category": "greetings", "modes": ["say", "hear"] },
  { "id": "g09", "english": "Please / I beg you", "japanese": "お願いします", "romaji": "onegaishimasu", "category": "greetings", "modes": ["say", "hear"], "notes": "Very common — attach to almost any request." },
  { "id": "g10", "english": "I'm OK / It's fine / No thank you", "japanese": "大丈夫です", "romaji": "daijoubu desu", "category": "greetings", "modes": ["say", "hear"], "notes": "Doubles as a polite refusal when shopkeepers offer something." },
  { "id": "g11", "english": "I don't understand", "japanese": "わかりません", "romaji": "wakarimasen", "category": "greetings", "modes": ["say", "hear"] },
  { "id": "g12", "english": "Do you speak English?", "japanese": "英語を話せますか", "romaji": "eigo o hanasemasu ka", "category": "greetings", "modes": ["say", "hear"] },

  { "id": "r01", "english": "Menu, please", "japanese": "メニューをお願いします", "romaji": "menyuu o onegaishimasu", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r02", "english": "Check, please", "japanese": "お会計をお願いします", "romaji": "okaikei o onegaishimasu", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r03", "english": "I'll have this (pointing)", "japanese": "これをください", "romaji": "kore o kudasai", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r04", "english": "What do you recommend?", "japanese": "おすすめは何ですか", "romaji": "osusume wa nan desu ka", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r05", "english": "Delicious!", "japanese": "美味しい", "romaji": "oishii", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r06", "english": "Water, please", "japanese": "お水をください", "romaji": "omizu o kudasai", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r07", "english": "I'm vegetarian", "japanese": "ベジタリアンです", "romaji": "bejitarian desu", "category": "restaurant", "modes": ["say", "hear"], "notes": "Vegetarianism is uncommon — be specific about what you don't eat." },
  { "id": "r08", "english": "No meat, please", "japanese": "肉なしでお願いします", "romaji": "niku nashi de onegaishimasu", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r09", "english": "I have an allergy", "japanese": "アレルギーがあります", "romaji": "arerugii ga arimasu", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r10", "english": "Table for one", "japanese": "一人です", "romaji": "hitori desu", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r11", "english": "Table for two", "japanese": "二人です", "romaji": "futari desu", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r12", "english": "Thank you for the meal (after eating)", "japanese": "ごちそうさまでした", "romaji": "gochisousama deshita", "category": "restaurant", "modes": ["say", "hear"], "notes": "Said when leaving the table or restaurant." },
  { "id": "r13", "english": "Said before eating", "japanese": "いただきます", "romaji": "itadakimasu", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r14", "english": "I'd like to order", "japanese": "注文お願いします", "romaji": "chuumon onegaishimasu", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r15", "english": "To go / takeout", "japanese": "持ち帰りで", "romaji": "mochikaeri de", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r16", "english": "For here / dine in", "japanese": "店内で", "romaji": "tennai de", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r17", "english": "What is this?", "japanese": "これは何ですか", "romaji": "kore wa nan desu ka", "category": "restaurant", "modes": ["say", "hear"] },
  { "id": "r18", "english": "Chopsticks, please", "japanese": "お箸をください", "romaji": "ohashi o kudasai", "category": "restaurant", "modes": ["say", "hear"] },

  { "id": "t01", "english": "Where is the station?", "japanese": "駅はどこですか", "romaji": "eki wa doko desu ka", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t02", "english": "Where can I buy a ticket?", "japanese": "切符はどこで買えますか", "romaji": "kippu wa doko de kaemasu ka", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t03", "english": "Does this go to Tokyo?", "japanese": "これは東京に行きますか", "romaji": "kore wa toukyou ni ikimasu ka", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t04", "english": "What's the next station?", "japanese": "次は何駅ですか", "romaji": "tsugi wa nani eki desu ka", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t05", "english": "Which platform?", "japanese": "何番線ですか", "romaji": "nanban sen desu ka", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t06", "english": "Please call a taxi", "japanese": "タクシーを呼んでください", "romaji": "takushii o yonde kudasai", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t07", "english": "Take me here, please (showing address)", "japanese": "ここまでお願いします", "romaji": "koko made onegaishimasu", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t08", "english": "I'm lost", "japanese": "道に迷いました", "romaji": "michi ni mayoimashita", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t09", "english": "Please show me on the map", "japanese": "地図で見せてください", "romaji": "chizu de misete kudasai", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t10", "english": "Can I walk there?", "japanese": "歩いて行けますか", "romaji": "aruite ikemasu ka", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t11", "english": "How long does it take?", "japanese": "どのくらいかかりますか", "romaji": "dono kurai kakarimasu ka", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t12", "english": "I'd like to charge my IC card", "japanese": "ICカードをチャージしたいです", "romaji": "ai shii kaado o chaaji shitai desu", "category": "transit", "modes": ["say", "hear"] },
  { "id": "t13", "english": "Where is the exit?", "japanese": "出口はどこですか", "romaji": "deguchi wa doko desu ka", "category": "transit", "modes": ["say", "hear"] },

  { "id": "h01", "english": "Check in, please", "japanese": "チェックインお願いします", "romaji": "chekku in onegaishimasu", "category": "hotel", "modes": ["say", "hear"] },
  { "id": "h02", "english": "Check out, please", "japanese": "チェックアウトお願いします", "romaji": "chekku auto onegaishimasu", "category": "hotel", "modes": ["say", "hear"] },
  { "id": "h03", "english": "I have a reservation", "japanese": "予約しています", "romaji": "yoyaku shiteimasu", "category": "hotel", "modes": ["say", "hear"] },
  { "id": "h04", "english": "What's the Wi-Fi password?", "japanese": "Wi-Fiのパスワードは何ですか", "romaji": "waifai no pasuwaado wa nan desu ka", "category": "hotel", "modes": ["say", "hear"] },
  { "id": "h05", "english": "Can you hold my luggage?", "japanese": "荷物を預かってもらえますか", "romaji": "nimotsu o azukatte moraemasu ka", "category": "hotel", "modes": ["say", "hear"] },
  { "id": "h06", "english": "What time is breakfast?", "japanese": "朝食は何時ですか", "romaji": "choushoku wa nanji desu ka", "category": "hotel", "modes": ["say", "hear"] },
  { "id": "h07", "english": "One more towel, please", "japanese": "タオルをもう一枚ください", "romaji": "taoru o mou ichimai kudasai", "category": "hotel", "modes": ["say", "hear"] },
  { "id": "h08", "english": "I lost my room key", "japanese": "部屋の鍵をなくしました", "romaji": "heya no kagi o nakushimashita", "category": "hotel", "modes": ["say", "hear"] },

  { "id": "s01", "english": "How much is it?", "japanese": "いくらですか", "romaji": "ikura desu ka", "category": "shopping", "modes": ["say", "hear"] },
  { "id": "s02", "english": "It's expensive", "japanese": "高いです", "romaji": "takai desu", "category": "shopping", "modes": ["say", "hear"] },
  { "id": "s03", "english": "It's cheap", "japanese": "安いです", "romaji": "yasui desu", "category": "shopping", "modes": ["say", "hear"] },
  { "id": "s04", "english": "Can I try it on?", "japanese": "試着できますか", "romaji": "shichaku dekimasu ka", "category": "shopping", "modes": ["say", "hear"] },
  { "id": "s05", "english": "Do you have a smaller size?", "japanese": "もう少し小さいサイズはありますか", "romaji": "mou sukoshi chiisai saizu wa arimasu ka", "category": "shopping", "modes": ["say", "hear"] },
  { "id": "s06", "english": "Do you have a larger size?", "japanese": "もう少し大きいサイズはありますか", "romaji": "mou sukoshi ookii saizu wa arimasu ka", "category": "shopping", "modes": ["say", "hear"] },
  { "id": "s07", "english": "Can I get tax-free?", "japanese": "免税できますか", "romaji": "menzei dekimasu ka", "category": "shopping", "modes": ["say", "hear"], "notes": "Bring your passport — many shops offer tax-free for tourists over a minimum spend." },
  { "id": "s08", "english": "Do you accept credit cards?", "japanese": "クレジットカードは使えますか", "romaji": "kurejitto kaado wa tsukaemasu ka", "category": "shopping", "modes": ["say", "hear"] },
  { "id": "s09", "english": "A bag, please", "japanese": "袋をください", "romaji": "fukuro o kudasai", "category": "shopping", "modes": ["say", "hear"] },
  { "id": "s10", "english": "Just looking", "japanese": "見ているだけです", "romaji": "miteiru dake desu", "category": "shopping", "modes": ["say", "hear"] },

  { "id": "e01", "english": "Help!", "japanese": "助けて", "romaji": "tasukete", "category": "emergency", "modes": ["say", "hear"] },
  { "id": "e02", "english": "Where is the hospital?", "japanese": "病院はどこですか", "romaji": "byouin wa doko desu ka", "category": "emergency", "modes": ["say", "hear"] },
  { "id": "e03", "english": "Where is the pharmacy?", "japanese": "薬局はどこですか", "romaji": "yakkyoku wa doko desu ka", "category": "emergency", "modes": ["say", "hear"] },
  { "id": "e04", "english": "I feel sick", "japanese": "気分が悪いです", "romaji": "kibun ga warui desu", "category": "emergency", "modes": ["say", "hear"] },
  { "id": "e05", "english": "Please call the police", "japanese": "警察を呼んでください", "romaji": "keisatsu o yonde kudasai", "category": "emergency", "modes": ["say", "hear"] },
  { "id": "e06", "english": "Please call an ambulance", "japanese": "救急車を呼んでください", "romaji": "kyuukyuusha o yonde kudasai", "category": "emergency", "modes": ["say", "hear"] },
  { "id": "e07", "english": "It hurts", "japanese": "痛いです", "romaji": "itai desu", "category": "emergency", "modes": ["say", "hear"] },
  { "id": "e08", "english": "I have a headache", "japanese": "頭が痛いです", "romaji": "atama ga itai desu", "category": "emergency", "modes": ["say", "hear"] },

  { "id": "p01", "english": "Nice to meet you", "japanese": "はじめまして", "romaji": "hajimemashite", "category": "social", "modes": ["say", "hear"] },
  { "id": "p02", "english": "How are you?", "japanese": "お元気ですか", "romaji": "ogenki desu ka", "category": "social", "modes": ["say", "hear"] },
  { "id": "p03", "english": "I'm well", "japanese": "元気です", "romaji": "genki desu", "category": "social", "modes": ["say", "hear"] },
  { "id": "p04", "english": "What's your name?", "japanese": "お名前は何ですか", "romaji": "onamae wa nan desu ka", "category": "social", "modes": ["say", "hear"] },
  { "id": "p05", "english": "I'm from America", "japanese": "アメリカから来ました", "romaji": "amerika kara kimashita", "category": "social", "modes": ["say", "hear"] },
  { "id": "p06", "english": "Pleased to meet you (formal)", "japanese": "よろしくお願いします", "romaji": "yoroshiku onegaishimasu", "category": "social", "modes": ["say", "hear"], "notes": "Hard to translate exactly — used at introductions and to seal any cooperative agreement." },
  { "id": "p07", "english": "Excuse me (entering or leaving)", "japanese": "失礼します", "romaji": "shitsurei shimasu", "category": "social", "modes": ["say", "hear"] },
  { "id": "p08", "english": "I'm sorry (sincere)", "japanese": "ごめんなさい", "romaji": "gomen nasai", "category": "social", "modes": ["say", "hear"] },
  { "id": "p09", "english": "Wonderful!", "japanese": "素晴らしい", "romaji": "subarashii", "category": "social", "modes": ["say", "hear"] },
  { "id": "p10", "english": "Cute!", "japanese": "かわいい", "romaji": "kawaii", "category": "social", "modes": ["say", "hear"] },

  { "id": "l01", "english": "Welcome! (shop greeting)", "japanese": "いらっしゃいませ", "romaji": "irasshaimase", "category": "listen", "modes": ["hear"], "notes": "You'll hear this at every shop and restaurant entrance. No reply needed." },
  { "id": "l02", "english": "Please wait a moment", "japanese": "少々お待ちください", "romaji": "shoushou omachi kudasai", "category": "listen", "modes": ["hear"] },
  { "id": "l03", "english": "Certainly / Understood", "japanese": "かしこまりました", "romaji": "kashikomarimashita", "category": "listen", "modes": ["hear"], "notes": "Polite acknowledgement from staff." },
  { "id": "l04", "english": "Sorry to keep you waiting", "japanese": "お待たせしました", "romaji": "omatase shimashita", "category": "listen", "modes": ["hear"] },
  { "id": "l05", "english": "Thank you (after service)", "japanese": "ありがとうございました", "romaji": "arigatou gozaimashita", "category": "listen", "modes": ["hear"], "notes": "Past-tense version — said when you leave a shop or finish a meal." },
  { "id": "l06", "english": "We will soon arrive at the next station", "japanese": "まもなく次の駅です", "romaji": "mamonaku tsugi no eki desu", "category": "listen", "modes": ["hear"] },
  { "id": "l07", "english": "The doors are closing", "japanese": "ドアが閉まります", "romaji": "doa ga shimarimasu", "category": "listen", "modes": ["hear"] },

